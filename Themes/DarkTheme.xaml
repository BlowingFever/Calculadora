<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════
        PALETA DE COLORES (Brushes reutilizables)
        ═══════════════════════════════════════
        Nombrar recursos con prefijo "Pincel" para distinguirlos de colores del sistema.
    -->

    <!-- Fondos -->
    <SolidColorBrush x:Key="PincelFondo"         Color="#0F111A"/>
    <!-- Ventana principal -->
    <SolidColorBrush x:Key="PincelSuperficie"    Color="#161B27"/>
    <!-- Paneles de botones -->
    <SolidColorBrush x:Key="PincelDisplay"       Color="#090B12"/>
    <!-- Fondo del display -->
    <SolidColorBrush x:Key="PincelNavBar"        Color="#0A0C14"/>
    <!-- Barra de navegación -->

    <!-- Botones -->
    <SolidColorBrush x:Key="PincelBtnDigito"     Color="#1E2235"/>
    <SolidColorBrush x:Key="PincelBtnOperador"   Color="#12213A"/>
    <SolidColorBrush x:Key="PincelBtnFuncion"    Color="#181F30"/>
    <SolidColorBrush x:Key="PincelBtnIgual"      Color="#1F6FEB"/>

    <!-- Textos -->
    <SolidColorBrush x:Key="PincelTexto"         Color="#E2E8F0"/>
    <SolidColorBrush x:Key="PincelTextoSec"      Color="#8B98A9"/>
    <SolidColorBrush x:Key="PincelTextoOp"       Color="#93C5FD"/>

    <!-- Acento -->
    <SolidColorBrush x:Key="PincelAcento"        Color="#1F6FEB"/>
    <SolidColorBrush x:Key="PincelBorde"         Color="#252843"/>

    <!--
        ═══════════════════════════════════════
        ESTILO GLOBAL: TextBlock
        Se aplica a todos los TextBlock sin necesidad de referenciarlo.
        ═══════════════════════════════════════
    -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource PincelTexto}"/>
    </Style>

    <!--
        ═══════════════════════════════════════
        PLANTILLA BASE PARA BOTONES DE CALCULADORA
        Bordes redondeados + feedback visual hover/pressed.
        Usada internamente por cada estilo de botón.
        ═══════════════════════════════════════
    -->

    <!-- Botón de Dígito (0–9) -->
    <Style x:Key="EstiloBotonDigito" TargetType="Button">
        <Setter Property="Foreground"               Value="{StaticResource PincelTexto}"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="22"/>
        <Setter Property="FontWeight"               Value="Normal"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="{StaticResource PincelBtnDigito}"
                            CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#262B48"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#181C2E"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón de Operador (+, −, ×, ÷) -->
    <Style x:Key="EstiloBotonOperador" TargetType="Button">
        <Setter Property="Foreground"               Value="{StaticResource PincelTextoOp}"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="24"/>
        <Setter Property="FontWeight"               Value="Light"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="{StaticResource PincelBtnOperador}"
                            CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#1A3055"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#0D1828"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón de Función (C, +/−, %) -->
    <Style x:Key="EstiloBotonFuncion" TargetType="Button">
        <Setter Property="Foreground"               Value="{StaticResource PincelTextoSec}"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="17"/>
        <Setter Property="FontWeight"               Value="SemiBold"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="{StaticResource PincelBtnFuncion}"
                            CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#222B40"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#101520"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón Igual (=) — Acento azul brillante -->
    <Style x:Key="EstiloBotonIgual" TargetType="Button">
        <Setter Property="Foreground"               Value="White"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="26"/>
        <Setter Property="FontWeight"               Value="Light"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="{StaticResource PincelBtnIgual}"
                            CornerRadius="10">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#388BFD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#1255C1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón de Navegación (barra inferior) -->
    <Style x:Key="EstiloBotonNav" TargetType="Button">
        <Setter Property="Foreground"               Value="{StaticResource PincelTextoSec}"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="12"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="Padding"                  Value="20,0"/>
        <Setter Property="Height"                   Value="38"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#1A1D2E"/>
                            <Setter Property="Foreground" Value="{StaticResource PincelTexto}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#0F111A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--
        ═══════════════════════════════════════
        ESTILOS DEL MÓDULO GRÁFICO
        Usados por GraphCalcView para la lista de expresiones.
        ═══════════════════════════════════════
    -->

    <!-- Botón plano (sin fondo): para "+" agregar y "×" eliminar expresión -->
    <Style x:Key="FlatButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource PincelTextoOp}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontFamily"       Value="Segoe UI"/>
        <Setter Property="FontSize"         Value="18"/>
        <Setter Property="Width"            Value="32"/>
        <Setter Property="Height"           Value="32"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Borde"
                            Background="Transparent"
                            CornerRadius="4">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#1A1D2E"/>
                            <Setter Property="Foreground" Value="{StaticResource PincelTexto}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Borde" Property="Background" Value="#0F111A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox de ecuación: fondo transparente, fuente monoespaciada -->
    <Style x:Key="ExpressionItemStyle" TargetType="TextBox">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Foreground"               Value="{StaticResource PincelTexto}"/>
        <Setter Property="CaretBrush"               Value="{StaticResource PincelTextoOp}"/>
        <Setter Property="SelectionBrush"           Value="{StaticResource PincelAcento}"/>
        <Setter Property="FontFamily"               Value="Consolas"/>
        <Setter Property="FontSize"                 Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding"                  Value="4,0"/>
        <!-- Placeholder gris cuando el campo está vacío -->
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Foreground" Value="{StaticResource PincelTexto}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>