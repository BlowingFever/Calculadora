<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--=====================================================-->
    <!--Shared Theme-->
    <!--=====================================================-->

    <!--Root Colors-->
    <Color x:Key="AccentColor">#E8820C</Color>
    <Color x:Key="AccentHoverColor">#F59220</Color>
    <Color x:Key="AccentPressedColor">#C96E08</Color>
    <Color x:Key="AccentForegroundColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="AccentBrush"             Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"      Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="{StaticResource AccentForegroundColor}"/>

    <!--=====================================================-->
    <!--Dark Theme-->
    <!--=====================================================-->
    <ResourceDictionary x:Key="Dark">

        <!--Window/General Background-->
        <Color x:Key="WindowBackgroundColor">#1E2128</Color>
        <SolidColorBrush x:Key="WindowBackgroundBrush">#1E2128</SolidColorBrush>

        <!--Outside Panel-->
        <Color x:Key="CalcSurfaceColor">#252830</Color>
        <SolidColorBrush x:Key="CalcSurfaceBrush">#252830</SolidColorBrush>

        <!--Display-->
        <Color x:Key="DisplayBackgroundColor">#1E2128</Color>
        <Color x:Key="DisplayExpressionForegroundColor">#6B7280</Color>
        <Color x:Key="DisplayResultForegroundColor">#F3F4F6</Color>

        <SolidColorBrush x:Key="DisplayBackgroundBrush">#1E2128</SolidColorBrush>
        <SolidColorBrush x:Key="DisplayExpressionForegroundBrush">#6B7280</SolidColorBrush>
        <SolidColorBrush x:Key="DisplayResultForegroundBrush">#F3F4F6</SolidColorBrush>

        <!--Numeric Buttons-->
        <Color x:Key="NumButtonBackgroundColor">#2E333D</Color>
        <Color x:Key="NumButtonHoverColor">#363C48</Color>
        <Color x:Key="NumButtonPressedColor">#23272F</Color>
        <Color x:Key="NumButtonForegroundColor">#E5E7EB</Color>

        <SolidColorBrush x:Key="NumButtonBackgroundBrush">#2E333D</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonHoverBrush">#363C48</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonPressedBrush">#23272F</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonForegroundBrush">#E5E7EB</SolidColorBrush>

        <!--Function Buttons (C, +/-, %)-->
        <Color x:Key="FuncButtonBackgroundColor">#3A404E</Color>
        <Color x:Key="FuncButtonHoverColor">#444B5A</Color>
        <Color x:Key="FuncButtonPressedColor">#2E333D</Color>
        <Color x:Key="FuncButtonForegroundColor">#CBD5E1</Color>

        <SolidColorBrush x:Key="FuncButtonBackgroundBrush">#3A404E</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonHoverBrush">#444B5A</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonPressedBrush">#2E333D</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonForegroundBrush">#CBD5E1</SolidColorBrush>

        <!--<Border / Separator-->
        <Color x:Key="BorderColor">#333844</Color>
        <SolidColorBrush x:Key="BorderBrush">#333844</SolidColorBrush>

        <!--Graphic Calculator-->
        <Color x:Key="GraphCanvasBackgroundColor">#12151A</Color>
        <Color x:Key="GraphGridLineColor">#2A2F3A</Color>
        <Color x:Key="GraphAxisColor">#9CA3AF</Color>

        <SolidColorBrush x:Key="GraphCanvasBackgroundBrush">#12151A</SolidColorBrush>
        <SolidColorBrush x:Key="GraphGridLineBrush">#2A2F3A</SolidColorBrush>
        <SolidColorBrush x:Key="GraphAxisBrush">#9CA3AF</SolidColorBrush>

        <!--Graphic Start Panel-->
        <Color x:Key="GraphInputBackgroundColor">#1E2128</Color>
        <Color x:Key="GraphInputForegroundColor">#E5E7EB</Color>
        <Color x:Key="GraphInputBorderColor">#333844</Color>
        <SolidColorBrush x:Key="GraphInputBackgroundBrush">#1E2128</SolidColorBrush>
        <SolidColorBrush x:Key="GraphInputForegroundBrush">#E5E7EB</SolidColorBrush>
        <SolidColorBrush x:Key="GraphInputBorderBrush">#333844</SolidColorBrush>
        <!--_______________????????????????????????????????????????????????????????????????????????-->

        <!-- Toggle de tema -->
        <Color x:Key="ThemeToggleForegroundColor">#9CA3AF</Color>
        <SolidColorBrush x:Key="ThemeToggleForegroundBrush">#9CA3AF</SolidColorBrush>

        <!-- Sombras neumórficas – en oscuro no hay neumorfismo real,   -->
        <!-- se usan transparentes para que DynamicResource no falle.   -->
        <Color x:Key="NeumorphicLightColor">#00000000</Color>
        <Color x:Key="NeumorphicDarkColor">#00000000</Color>
        <SolidColorBrush x:Key="NeumorphicLightBrush">Transparent</SolidColorBrush>
        <SolidColorBrush x:Key="NeumorphicDarkBrush">Transparent</SolidColorBrush>

    </ResourceDictionary>

    <!-- ============================================================ -->
    <!--  TEMA CLARO                                                    -->
    <!-- ============================================================ -->
    <ResourceDictionary x:Key="Light">

        <!-- Ventana / fondo general -->
        <Color x:Key="WindowBackgroundColor">#E8EAF0</Color>
        <SolidColorBrush x:Key="WindowBackgroundBrush">#E8EAF0</SolidColorBrush>

        <!-- Superficie de la calculadora -->
        <Color x:Key="CalcSurfaceColor">#F0F2F7</Color>
        <SolidColorBrush x:Key="CalcSurfaceBrush">#F0F2F7</SolidColorBrush>

        <!-- Display -->
        <Color x:Key="DisplayBackgroundColor">#F0F2F7</Color>
        <Color x:Key="DisplayExpressionForegroundColor">#9CA3AF</Color>
        <Color x:Key="DisplayResultForegroundColor">#1F2937</Color>
        <SolidColorBrush x:Key="DisplayBackgroundBrush">#F0F2F7</SolidColorBrush>
        <SolidColorBrush x:Key="DisplayExpressionForegroundBrush">#9CA3AF</SolidColorBrush>
        <SolidColorBrush x:Key="DisplayResultForegroundBrush">#1F2937</SolidColorBrush>

        <!-- Botones numéricos -->
        <Color x:Key="NumButtonBackgroundColor">#E8EAF0</Color>
        <Color x:Key="NumButtonHoverColor">#DDE0E8</Color>
        <Color x:Key="NumButtonPressedColor">#D0D3DC</Color>
        <Color x:Key="NumButtonForegroundColor">#1F2937</Color>
        <SolidColorBrush x:Key="NumButtonBackgroundBrush">#E8EAF0</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonHoverBrush">#DDE0E8</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonPressedBrush">#D0D3DC</SolidColorBrush>
        <SolidColorBrush x:Key="NumButtonForegroundBrush">#1F2937</SolidColorBrush>

        <!-- Botones de función -->
        <Color x:Key="FuncButtonBackgroundColor">#DDE0EA</Color>
        <Color x:Key="FuncButtonHoverColor">#D0D4DE</Color>
        <Color x:Key="FuncButtonPressedColor">#C4C8D2</Color>
        <Color x:Key="FuncButtonForegroundColor">#374151</Color>
        <SolidColorBrush x:Key="FuncButtonBackgroundBrush">#DDE0EA</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonHoverBrush">#D0D4DE</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonPressedBrush">#C4C8D2</SolidColorBrush>
        <SolidColorBrush x:Key="FuncButtonForegroundBrush">#374151</SolidColorBrush>

        <!-- Borde / separadores -->
        <Color x:Key="BorderColor">#D1D5DB</Color>
        <SolidColorBrush x:Key="BorderBrush">#D1D5DB</SolidColorBrush>

        <!-- Calculadora gráfica -->
        <Color x:Key="GraphCanvasBackgroundColor">#FFFFFF</Color>
        <Color x:Key="GraphGridLineColor">#E5E7EB</Color>
        <Color x:Key="GraphAxisColor">#9CA3AF</Color>
        <SolidColorBrush x:Key="GraphCanvasBackgroundBrush">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="GraphGridLineBrush">#E5E7EB</SolidColorBrush>
        <SolidColorBrush x:Key="GraphAxisBrush">#9CA3AF</SolidColorBrush>

        <!-- Panel de entrada gráfica -->
        <Color x:Key="GraphInputBackgroundColor">#F5F7FA</Color>
        <Color x:Key="GraphInputForegroundColor">#1F2937</Color>
        <Color x:Key="GraphInputBorderColor">#D1D5DB</Color>
        <SolidColorBrush x:Key="GraphInputBackgroundBrush">#F5F7FA</SolidColorBrush>
        <SolidColorBrush x:Key="GraphInputForegroundBrush">#1F2937</SolidColorBrush>
        <SolidColorBrush x:Key="GraphInputBorderBrush">#D1D5DB</SolidColorBrush>

        <!-- Toggle de tema -->
        <Color x:Key="ThemeToggleForegroundColor">#6B7280</Color>
        <SolidColorBrush x:Key="ThemeToggleForegroundBrush">#6B7280</SolidColorBrush>

        <!-- Sombras neumórficas (solo relevantes en tema claro) -->
        <Color x:Key="NeumorphicLightColor">#FFFFFF</Color>
        <Color x:Key="NeumorphicDarkColor">#C8CDD8</Color>
        <SolidColorBrush x:Key="NeumorphicLightBrush">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="NeumorphicDarkBrush">#C8CDD8</SolidColorBrush>

    </ResourceDictionary>

</ResourceDictionary>