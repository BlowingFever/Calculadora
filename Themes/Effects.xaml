<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        EFFECTS, ANIMATIONS AND TRIGGERS

        Required load order in App.xaml:
          1. Typography.xaml  — defines GraphInputTextStyle
          2. Colors.xaml      — defines theme brushes
          3. Effects.xaml     — consumes BasedOn and DynamicResource references
    -->

    <!-- ── Geometry ──────────────────────────────────────────────────────── -->
    <CornerRadius x:Key="ButtonCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="DisplayCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="CalcSurfaceCornerRadius">28</CornerRadius>
    <CornerRadius x:Key="GraphPanelCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="InputFieldCornerRadius">10</CornerRadius>

    <!-- ── Button sizes ───────────────────────────────────────────────────── -->
    <sys:Double x:Key="ButtonSize">68</sys:Double>
    <sys:Double x:Key="ButtonSpacing">10</sys:Double>

    <!-- ── Animation durations ───────────────────────────────────────────── -->
    <Duration x:Key="HoverDuration">0:0:0.12</Duration>
    <Duration x:Key="PressDuration">0:0:0.07</Duration>
    <Duration x:Key="ReleaseDuration">0:0:0.15</Duration>

    <!-- ── Opacities ─────────────────────────────────────────────────────── -->
    <sys:Double x:Key="DisabledOpacity">0.38</sys:Double>
    <sys:Double x:Key="ButtonPressedScale">0.94</sys:Double>

    <!-- ── Easing functions ───────────────────────────────────────────────── -->
    <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseIn"  EasingMode="EaseIn"/>

    <!-- ============================================================ -->
    <!-- BASE BUTTON STYLE                                             -->
    <!-- Animates only scale on press (theme-independent).            -->
    <!-- Child styles handle colour via property Setters in Triggers. -->
    <!-- ============================================================ -->
    <Style x:Key="CalcButtonBaseStyle" TargetType="Button">
        <Setter Property="MinWidth"              Value="32"/>
        <Setter Property="MinHeight"             Value="32"/>
        <Setter Property="FontFamily"            Value="{StaticResource PrimaryFontFamily}"/>
        <Setter Property="FontWeight"            Value="Medium"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ButtonCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Scale on press -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="{StaticResource ButtonPressedScale}"
                                            Duration="{StaticResource PressDuration}"
                                            EasingFunction="{StaticResource EaseIn}"/>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="{StaticResource ButtonPressedScale}"
                                            Duration="{StaticResource PressDuration}"
                                            EasingFunction="{StaticResource EaseIn}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="1"
                                            Duration="{StaticResource ReleaseDuration}"
                                            EasingFunction="{StaticResource EaseOut}"/>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="1"
                                            Duration="{StaticResource ReleaseDuration}"
                                            EasingFunction="{StaticResource EaseOut}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Disabled state -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{StaticResource DisabledOpacity}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- NUMERIC BUTTON STYLE (0–9)                                   -->
    <!-- ============================================================ -->
    <Style x:Key="NumButtonStyle" TargetType="Button"
           BasedOn="{StaticResource CalcButtonBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource NumButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NumButtonForegroundBrush}"/>
        <Setter Property="FontSize"   Value="{StaticResource NumButtonFontSize}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource NumButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource NumButtonPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================ -->
    <!-- OPERATOR BUTTON STYLE (÷ × − + =)                           -->
    <!-- ============================================================ -->
    <Style x:Key="OpButtonStyle" TargetType="Button"
           BasedOn="{StaticResource CalcButtonBaseStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
        <Setter Property="FontSize"   Value="{StaticResource OpButtonFontSize}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================ -->
    <!-- FUNCTION BUTTON STYLE (C, +/−, %)                           -->
    <!-- ============================================================ -->
    <Style x:Key="FuncButtonStyle" TargetType="Button"
           BasedOn="{StaticResource CalcButtonBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource FuncButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource FuncButtonForegroundBrush}"/>
        <Setter Property="FontSize"   Value="{StaticResource FuncButtonFontSize}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource FuncButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource FuncButtonPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================ -->
    <!-- ZERO BUTTON STYLE (double-width, left-aligned label)         -->
    <!-- ============================================================ -->
    <Style x:Key="ZeroButtonStyle" TargetType="Button"
           BasedOn="{StaticResource NumButtonStyle}">
        <Setter Property="Width"                      Value="Auto"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"                    Value="26,0,0,0"/>
    </Style>

    <!-- ============================================================ -->
    <!-- CALCULATOR DISPLAY STYLE                                      -->
    <!-- ============================================================ -->
    <Style x:Key="CalcDisplayStyle" TargetType="Border">
        <Setter Property="Background"   Value="{DynamicResource DisplayBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource DisplayCornerRadius}"/>
        <Setter Property="Padding"      Value="20,16,20,12"/>
    </Style>

    <!-- ============================================================ -->
    <!-- GRAPH FUNCTION INPUT STYLE                                    -->
    <!-- BasedOn references GraphInputTextStyle from Typography.xaml. -->
    <!-- ============================================================ -->
    <Style x:Key="GraphFunctionInputStyle" TargetType="TextBox"
           BasedOn="{StaticResource GraphInputTextStyle}">
        <Setter Property="Background"      Value="{DynamicResource GraphInputBackgroundBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource GraphInputForegroundBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource GraphInputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource InputFieldCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Accent border on focus -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <!-- Subtle hover highlight -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- THEME TOGGLE BUTTON STYLE (light / dark switch)              -->
    <!--                                                              -->
    <!-- Custom template removes the default blue IsChecked tint.    -->
    <!-- ============================================================ -->
    <Style x:Key="ThemeToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Width"                 Value="32"/>
        <Setter Property="Height"                Value="32"/>
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="Cursor"                Value="Hand"/>
        <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
        <Setter Property="Foreground"            Value="{DynamicResource ThemeToggleForegroundBrush}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource FuncButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource FuncButtonPressedBrush}"/>
                        </Trigger>
                        <!-- Keep background transparent when checked (no blue tint) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="0.88" Duration="{StaticResource PressDuration}"
                                EasingFunction="{StaticResource EaseIn}"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="0.88" Duration="{StaticResource PressDuration}"
                                EasingFunction="{StaticResource EaseIn}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1" Duration="{StaticResource ReleaseDuration}"
                                EasingFunction="{StaticResource EaseOut}"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1" Duration="{StaticResource ReleaseDuration}"
                                EasingFunction="{StaticResource EaseOut}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================ -->
    <!-- DROP SHADOWS                                                  -->
    <!--                                                              -->
    <!-- DropShadowEffect.Color only accepts a literal Color value;   -->
    <!-- DynamicResource is not supported here, so colours are fixed. -->
    <!-- ============================================================ -->
    <DropShadowEffect x:Key="CalcSurfaceShadow"
                      BlurRadius="32"
                      ShadowDepth="8"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.22"
                      RenderingBias="Quality"/>

    <DropShadowEffect x:Key="ButtonShadow"
                      BlurRadius="8"
                      ShadowDepth="3"
                      Direction="270"
                      Color="#000000"
                      Opacity="0.14"
                      RenderingBias="Performance"/>

</ResourceDictionary>
