<UserControl x:Class="Calculadora.Views.GraphCalcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="180" MaxWidth="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <DockPanel Grid.Column="0"
                   Background="{DynamicResource CalcSurfaceBrush}">

            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource CalcSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel>
                    <TextBlock Text="Expresiones"
                               Foreground="{DynamicResource DisplayResultForegroundBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <!-- Botón "+" pequeño, sin heredar el tamaño 68×68 de FuncButtonStyle -->
                    <Button DockPanel.Dock="Right"
                            Content="+"
                            Width="32" Height="32"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="{DynamicResource FuncButtonBackgroundBrush}"
                            Foreground="{DynamicResource FuncButtonForegroundBrush}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding AddExpressionCommand}"
                            ToolTip="Agregar expresión">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background"
                                                Value="{DynamicResource FuncButtonHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Root" Property="Background"
                                                Value="{DynamicResource FuncButtonPressedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Expressions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    MinHeight="52">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Rectangle Grid.Column="0" Fill="{Binding Color}"/>

                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding Visible}"
                                              Margin="8,0"
                                              VerticalAlignment="Center"/>

                                    <TextBox Grid.Column="2"
                                             Style="{DynamicResource GraphFunctionInputStyle}"
                                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"/>

                                    <!-- Botón "×" pequeño igual que el "+" -->
                                    <Button Grid.Column="3"
                                            Content="×"
                                            Width="32" Height="32"
                                            FontSize="16"
                                            Background="Transparent"
                                            Foreground="{DynamicResource DisplayExpressionForegroundBrush}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="4,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Eliminar expresión"
                                            Command="{Binding DataContext.RemoveExpressionCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{DynamicResource FuncButtonHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Root" Property="Background"
                                                                Value="{DynamicResource FuncButtonPressedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <GridSplitter Grid.Column="0"
                      Width="4"
                      HorizontalAlignment="Right"
                      Background="{DynamicResource BorderBrush}"
                      Cursor="SizeWE"/>

        <!-- PANEL DERECHO — gráfico -->
        <Grid Grid.Column="1"
              Background="{DynamicResource GraphCanvasBackgroundBrush}">
            <scottplot:WpfPlot x:Name="WpfPlot"/>
        </Grid>

    </Grid>
</UserControl>