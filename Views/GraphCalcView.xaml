<UserControl x:Class="Calculadora.Views.GraphCalcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">

    <!--
        El DataContext aquí es GraphCalcViewModel,
        asignado automáticamente por el DataTemplate de App.xaml.

        LAYOUT: Dos columnas.
          Columna 0 → Panel de expresiones (ancho fijo, redimensionable con el splitter)
          Columna 1 → Zona del gráfico (ocupa todo el espacio restante)
    -->
    <Grid Background="{StaticResource PincelFondo}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="180" MaxWidth="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════
             PANEL IZQUIERDO — Lista de expresiones
             ════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="{StaticResource PincelNavBar}">

            <!-- Cabecera: título + botón "+" -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource PincelNavBar}"
                    BorderBrush="{StaticResource PincelBorde}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel>
                    <TextBlock Text="Expresiones"
                               Foreground="{StaticResource PincelTextoOp}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <!--
                        Botón "+": al pulsarlo ejecuta AddExpressionCommand del ViewModel.
                        Sin código en el code-behind. Solo un Binding.
                    -->
                    <Button DockPanel.Dock="Right"
                            Content="+"
                            FontSize="22"
                            FontWeight="Bold"
                            Style="{StaticResource FlatButtonStyle}"
                            Command="{Binding AddExpressionCommand}"
                            ToolTip="Agregar expresión"/>
                </DockPanel>
            </Border>

            <!-- Lista dinámica de expresiones -->
            <!--
                ItemsControl recorre la colección Expressions del ViewModel
                y pinta un bloque visual por cada elemento.
                Cuando se agrega o elimina un elemento, la UI se actualiza
                sola gracias a ObservableCollection. Sin código extra.
            -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Expressions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Todo lo que hay aquí dentro representa
                                UNA expresión de la lista.
                                El DataContext aquí es automáticamente
                                cada ExpressionItem individual.
                            -->
                            <Border BorderBrush="{StaticResource PincelBorde}"
                                    BorderThickness="0,0,0,1"
                                    MinHeight="52">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Franja de color de la curva -->
                                        <ColumnDefinition Width="6"/>
                                        <!-- Checkbox de visibilidad -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Campo de texto de la ecuación -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Botón eliminar -->
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Franja de color: bindada a ExpressionItem.Color -->
                                    <Rectangle Grid.Column="0"
                                               Fill="{Binding Color}"/>

                                    <!-- Checkbox para mostrar/ocultar la curva -->
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding Visible}"
                                              Margin="8,0"
                                              VerticalAlignment="Center"/>

                                    <!--
                                        Campo de texto de la ecuación.
                                        UpdateSourceTrigger=PropertyChanged hace que
                                        el ViewModel reciba el texto en cada tecla,
                                        no solo cuando el campo pierde el foco.
                                    -->
                                    <TextBox Grid.Column="2"
                                             Style="{StaticResource ExpressionItemStyle}"
                                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"/>

                                    <!--
                                        Botón "×" para eliminar esta expresión.

                                        TRUCO IMPORTANTE:
                                        Dentro del DataTemplate, el DataContext es
                                        el ExpressionItem, no el GraphCalcViewModel.
                                        Para llegar a RemoveExpressionCommand usamos
                                        RelativeSource para subir hasta el UserControl
                                        y acceder a su DataContext.
                                        CommandParameter envía el propio ExpressionItem
                                        para que el VM sepa cuál eliminar.
                                    -->
                                    <Button Grid.Column="3"
                                            Content="×"
                                            Style="{StaticResource FlatButtonStyle}"
                                            Foreground="{StaticResource PincelTextoSec}"
                                            VerticalAlignment="Center"
                                            ToolTip="Eliminar expresión"
                                            Command="{Binding DataContext.RemoveExpressionCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>

        <!-- Barra separadora que el usuario puede arrastrar para redimensionar -->
        <GridSplitter Grid.Column="0"
                      Width="4"
                      HorizontalAlignment="Right"
                      Background="{StaticResource PincelBorde}"
                      Cursor="SizeWE"/>

        <!-- ════════════════════════════════════════════
             PANEL DERECHO — Zona del gráfico
             ════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource PincelDisplay}">
            <scottplot:WpfPlot x:Name="WpfPlot"/>
        </Grid>

    </Grid>
</UserControl>