<UserControl x:Class="Calculadora.Views.NormalCalcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- DISPLAY -->
        <Border Grid.Row="0"
                Background="{DynamicResource DisplayBackgroundBrush}"
                Padding="24,20,24,16">
            <StackPanel>
                <TextBlock Text="{Binding Expression}"
                           Style="{DynamicResource DisplayExpressionTextStyle}"
                           Foreground="{DynamicResource DisplayExpressionForegroundBrush}"
                           MinHeight="20"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Display}"
                           Style="{DynamicResource DisplayResultTextStyle}"
                           Foreground="{DynamicResource DisplayResultForegroundBrush}"/>
            </StackPanel>
        </Border>

        <!-- BUTTON GRID: Grid that occupies all remaining space -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0 -->
            <Button Grid.Row="0" Grid.Column="0"
                    Content="C" Margin="5"
                    Style="{DynamicResource FuncButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding ClearCommand}"/>
            <Button Grid.Row="0" Grid.Column="1"
                    Content="+/−" Margin="5"
                    Style="{DynamicResource FuncButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding ToggleSignCommand}"/>
            <Button Grid.Row="0" Grid.Column="2"
                    Content="%" Margin="5"
                    Style="{DynamicResource FuncButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding PercentCommand}"/>
            <Button Grid.Row="0" Grid.Column="3"
                    Content="÷" Margin="5"
                    Style="{DynamicResource OpButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding OperatorCommand}" CommandParameter="/"/>

            <!-- Row 1 -->
            <Button Grid.Row="1" Grid.Column="0"
                    Content="7" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="7"/>
            <Button Grid.Row="1" Grid.Column="1"
                    Content="8" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="8"/>
            <Button Grid.Row="1" Grid.Column="2"
                    Content="9" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="9"/>
            <Button Grid.Row="1" Grid.Column="3"
                    Content="×" Margin="5"
                    Style="{DynamicResource OpButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding OperatorCommand}" CommandParameter="*"/>

            <!-- Row 2 -->
            <Button Grid.Row="2" Grid.Column="0"
                    Content="4" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="4"/>
            <Button Grid.Row="2" Grid.Column="1"
                    Content="5" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="5"/>
            <Button Grid.Row="2" Grid.Column="2"
                    Content="6" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="6"/>
            <Button Grid.Row="2" Grid.Column="3"
                    Content="−" Margin="5"
                    Style="{DynamicResource OpButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding OperatorCommand}" CommandParameter="-"/>

            <!-- Row 3 -->
            <Button Grid.Row="3" Grid.Column="0"
                    Content="1" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="1"/>
            <Button Grid.Row="3" Grid.Column="1"
                    Content="2" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="2"/>
            <Button Grid.Row="3" Grid.Column="2"
                    Content="3" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DigitCommand}" CommandParameter="3"/>
            <Button Grid.Row="3" Grid.Column="3"
                    Content="+" Margin="5"
                    Style="{DynamicResource OpButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding OperatorCommand}" CommandParameter="+"/>

            <!-- Row 4: 0 spans 2 columns -->
            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Content="0" Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    HorizontalContentAlignment="Left"
                    Padding="24,0,0,0"
                    Command="{Binding DigitCommand}" CommandParameter="0"/>
            <Button Grid.Row="4" Grid.Column="2"
                    Content="." Margin="5"
                    Style="{DynamicResource NumButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding DecimalCommand}"/>
            <Button Grid.Row="4" Grid.Column="3"
                    Content="=" Margin="5"
                    Style="{DynamicResource OpButtonStyle}"
                    Width="Auto" Height="Auto"
                    Command="{Binding EqualsCommand}"/>
        </Grid>
    </Grid>
</UserControl>