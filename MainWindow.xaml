<Window x:Class="Calculadora.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Calculadora.ViewModels"
        xmlns:models="clr-namespace:Calculadora.Models"
        Title="Calculator"
        Width="460" Height="620"
        MinWidth="380" MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource CalcSurfaceBrush}"
            CornerRadius="{StaticResource CalcSurfaceCornerRadius}"
            Margin="16"
            Effect="{StaticResource CalcSurfaceShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Active view host — DataTemplate resolved automatically by WPF -->
            <ContentControl Grid.Row="0"
                            Content="{Binding CurrentView}"
                            PreviewKeyDown="OnPreviewKeyDown"/>

            <!-- Horizontal separator above the bottom navigation bar -->
            <Border Grid.Row="0"
                    VerticalAlignment="Bottom"
                    Height="1"
                    Background="{DynamicResource BorderBrush}"/>

            <!-- Bottom navigation bar -->
            <Grid Grid.Row="1"
                  Background="{DynamicResource CalcSurfaceBrush}"
                  Margin="10,6,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- View-switch buttons -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="Calculator"
                            Style="{DynamicResource FuncButtonStyle}"
                            Width="120" Height="10"
                            Padding="16,0"
                            Command="{Binding ShowNormalCalculatorCommand}"/>
                    <Border Width="1"
                            Background="{DynamicResource BorderBrush}"
                            Margin="10,5"/>
                    <Button Content="Graph"
                            Style="{DynamicResource FuncButtonStyle}"
                            Width="80" Height="10"
                            Padding="16,0"
                            Command="{Binding ShowGraphCalculatorCommand}"/>
                </StackPanel>

                <!--
                    Theme toggle button: transparent background inherits CalcSurfaceBrush
                    from the parent Grid. ThemeToggleButtonStyle already sets Background=Transparent.
                -->
                <models:ThemeToggleButton
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="4,0,8,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
