<Application
    x:Class="Calculadora.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Calculadora.ViewModels"
    xmlns:views="clr-namespace:Calculadora.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Typography.xaml"/>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Effects.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:NormalCalcViewModel}">
                <views:NormalCalcView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GraphCalcViewModel}">
                <views:GraphCalcView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>